{
	"always_treat_brackets_as_autoclosed": true,
	"auto_indent": "syntax_aware",
	"code_actions_on_format": {
		"source.fixAll": true,
		"source.organizeImports": false
	},
	"colorize_brackets": true,
	"disable_ai": false,
	"edit_predictions": {
		"codestral": {},
		"copilot": { "enable_next_edit_suggestions": true },
		"mode": "eager"
	},
	"ensure_final_newline_on_save": true,
	"file_types": {
		"JSONC": [
			"tsconfig.json",
			"jsconfig.json",
			".vscode/*.json",
			".oxfmtrc.json",
			".oxlintrc.json",
			"*.code-workspace",
			"tsconfig*.json",
			"*.code-snippets"
		],
		"Shell Script": [
			"zsh",
			"zshrc",
			"zprofile",
			"zshenv",
			"bashrc",
			"bash_profile"
		],
		"TOML": ["toml"],
		"YAML": [
			"*.yml",
			"*.yaml",
			".github/workflows/*.yml",
			".github/workflows/*.yaml"
		]
	},
	"format_on_save": "on",
	"hard_tabs": true,
	"indent_guides": {
		"active_line_width": 1,
		"background_coloring": "disabled",
		"coloring": "indent_aware",
		"enabled": true,
		"line_width": 1
	},
	"inlay_hints": {
		"edit_debounce_ms": 700,
		"enabled": true,
		"scroll_debounce_ms": 50,
		"show_other_hints": true,
		"show_parameter_hints": true,
		"show_type_hints": true
	},
	"jsx_tag_auto_close": { "enabled": true },
	"languages": {
		"JSON": {
			"format_on_save": "on",
			"formatter": [
				{
					"language_server": { "name": "biome" }
				},
				{
					"language_server": { "name": "oxfmt" }
				}
			],
			"hard_tabs": true,
			"language_servers": [
				"!eslint",
				"biome",
				"package-version-server",
				"oxfmt",
				"..."
			],
			"prettier": { "allowed": false },
			"tab_size": 4
		},
		"JSONC": {
			"format_on_save": "on",
			"formatter": [
				{
					"language_server": { "name": "biome" }
				},
				{
					"language_server": { "name": "oxfmt" }
				}
			],
			"hard_tabs": true,
			"language_servers": [
				"!eslint",
				"biome",
				"package-version-server",
				"oxfmt",
				"..."
			],
			"prettier": { "allowed": false },
			"tab_size": 4
		},
		"Markdown": {
			"format_on_save": "on",
			"formatter": {
				"language_server": { "name": "rumdl" }
			},
			"hard_tabs": true,
			"language_servers": ["!marksman", "!markdownlint", "rumdl", "..."],
			"prettier": { "allowed": false },
			"show_whitespaces": "none",
			"tab_size": 4
		},
		"MDX": {
			"format_on_save": "on",
			"formatter": {
				"language_server": { "name": "oxfmt" }
			},
			"language_servers": ["!eslint", "oxfmt", "..."],
			"prettier": { "allowed": false }
		},
		"Rust": {
			"prettier": { "allowed": false }
		},
		"Shell Script": {
			"format_on_save": "on",
			"formatter": {
				"external": {
					"arguments": ["-i", "4", "-bn", "-ci", "-sr"],
					"command": "shfmt"
				}
			},
			"hard_tabs": true,
			"language_servers": ["bash-language-server", "..."],
			"tab_size": 4
		},
		"TOML": {
			"format_on_save": "on",
			"formatter": "language_server",
			"hard_tabs": true,
			"tab_size": 4
		},
		"YAML": {
			"format_on_save": "on",
			"formatter": {
				"language_server": { "name": "oxfmt" }
			},
			"hard_tabs": false,
			"prettier": { "allowed": false },
			"tab_size": 2
		}
	},
	"lsp": {
		"bash-language-server": {
			"settings": {
				"bashIde": {
					"globPattern": "**/*@(.sh|.inc|.bash|.command|.zsh)"
				}
			}
		},
		"biome": {
			"binary": {
				"arguments": ["biome", "lsp-proxy"],
				"path": "aubr"
			}
		},
		"oxfmt": {
			"initialization_options": {
				"settings": {
					"configPath": ".oxfmtrc.json",
					"run": "onSave"
				}
			}
		},
		"rust-analyzer": {
			"enable_lsp_tasks": true,
			"initialization_options": {
				"cargo": {
					"allTargets": true,
					"buildScripts": { "enable": true },
					"features": "all",
					"targetDir": true
				},
				"check": {
					"allTargets": true,
					"command": "clippy",
					"features": "all",
					"workspace": true
				},
				"checkOnSave": true,
				"diagnostics": {
					"experimental": { "enable": true },
					"styleLints": { "enable": true }
				},
				"inlayHints": {
					"bindingModeHints": { "enable": true },
					"chainingHints": { "enable": true },
					"closureCaptureHints": { "enable": true },
					"closureReturnTypeHints": { "enable": "always" },
					"genericParameterHints": {
						"const": { "enable": true },
						"lifetime": { "enable": true },
						"type": { "enable": true }
					},
					"lifetimeElisionHints": {
						"enable": "skip_trivial",
						"useParameterNames": true
					},
					"maxLength": null,
					"parameterHints": {
						"enable": true,
						"missingArguments": { "enable": true }
					},
					"typeHints": { "enable": true }
				},
				"procMacro": { "enable": true }
			}
		},
		"yaml-language-server": {
			"settings": {
				"yaml": {
					"format": { "singleQuote": true },
					"keyOrdering": true,
					"schemas": {
						"./schemas/kubernetes.yaml": "k8s/**/*.yaml",
						"~/global-schemas/docker-compose.yaml": "docker-compose*.yml",
						"https://getcomposer.org/schema.json": ["/*"],
						"https://raw.githubusercontent.com/rvben/rumdl/main/rumdl.schema.json": [
							"**/.rumdl.toml",
							"**/rumdl.toml"
						]
					}
				}
			}
		}
	},
	"prettier": { "allowed": false },
	"remove_trailing_whitespace_on_save": true,
	"show_completion_documentation": true,
	"show_completions_on_input": true,
	"show_edit_predictions": true,
	"soft_wrap": "prefer_line",
	"tab_size": 4,
	"terminal": {
		"shell": "system",
		"working_directory": "current_project_directory"
	},
	"use_auto_surround": true,
	"use_autoclose": true,
	"use_on_type_format": true
}
